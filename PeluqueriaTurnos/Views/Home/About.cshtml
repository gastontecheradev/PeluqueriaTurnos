@{
    ViewData["Title"] = "El Studio";
}

<section class="nf-section">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-md-6">
                <h1 class="nf-section-title mb-3">NovaFade Studio</h1>
                <p class="lead text-muted">
                    Un espacio moderno donde combinamos técnica, estilo y una experiencia
                    cómoda desde que reservás tu turno hasta que salís con corte nuevo.
                </p>
                <p class="text-muted">
                    Trabajamos solo con atención por turno para respetar tu tiempo.
                    Mientras esperás, tenés café, agua y Wi-Fi disponible.
                </p>
            </div>
            <div class="col-md-6">
                <div class="nf-card nf-card-photo h-100">
                    <img src="/img/hero/hero-barber.jpg" alt="Interior de NovaFade Studio" class="img-fluid" />
                </div>
            </div>
        </div>
    </div>
</section>
