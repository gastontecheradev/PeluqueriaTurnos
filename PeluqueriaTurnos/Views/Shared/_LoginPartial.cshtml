@using Microsoft.AspNetCore.Identity
@using PeluqueriaTurnos.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav ms-lg-3">
    @if (SignInManager.IsSignedIn(User))
    {
        var user = await UserManager.GetUserAsync(User);
        <li class="nav-item d-flex align-items-center">
            <span class="nav-link text-light small me-1">
                Hola, @user!.FullName
            </span>
        </li>
        <li class="nav-item">
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@(Url.Action("Index", "Home"))" method="post" class="d-inline">
                <button type="submit" class="btn btn-sm nf-btn-secondary">
                    Cerrar sesión
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="btn btn-sm nf-btn-outline me-2" asp-area="Identity" asp-page="/Account/Login">Ingresar</a>
        </li>
        <li class="nav-item">
            <a class="btn btn-sm nf-btn-primary" asp-area="Identity" asp-page="/Account/Register">Crear cuenta</a>
        </li>
    }
</ul>
