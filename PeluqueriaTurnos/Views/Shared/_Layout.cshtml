@using Microsoft.AspNetCore.Identity
@using PeluqueriaTurnos.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NovaFade Studio</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="crossorigin" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/img/favicon.png">

    <!-- Open Graph -->
    <meta property="og:title" content="NovaFade" />
    <meta property="og:description" content="NovaFade Barberia" />
    <meta property="og:image" content="https://novafadestudio.somee.com/img/og-image.jpg" />
    <meta property="og:type" content="website" />
</head>
<body class="nf-body">
    <header class="nf-header">
        <nav class="navbar navbar-expand-lg navbar-dark nf-navbar">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <div class="nf-logo me-2">NF</div>
                    <div class="nf-brand-text">
                        <span class="fw-bold">NovaFade Studio</span>
                        <small class="d-block text-secondary">Peluquería & Barbería</small>
                    </div>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">El Studio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contact">Contacto</a>
                        </li>
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Appointments" asp-action="Create">Reservar turno</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Appointments" asp-action="My">Mis turnos</a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Appointments" asp-action="Index">Panel turnos</a>
                                </li>
                            }
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main class="nf-main">
        @RenderBody()
    </main>

    <footer class="nf-footer">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
            <div>
                <strong>NovaFade Studio</strong> &copy; @DateTime.Now.Year
                <span class="text-secondary ms-2">Montevideo, Uruguay</span>
            </div>
            <div class="nf-footer-links">
                <a asp-controller="Home" asp-action="Contact">Agendá tu turno</a>
                <span class="mx-2">·</span>
                <a href="#">Instagram</a>
                <span class="mx-2">·</span>
                <a href="#">WhatsApp</a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
