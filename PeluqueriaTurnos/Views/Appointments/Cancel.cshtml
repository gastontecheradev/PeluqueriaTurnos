@model PeluqueriaTurnos.Models.Appointment
@{
    ViewData["Title"] = "Cancelar turno";
}

<section class="nf-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="nf-card nf-card-warning">
                    <h1 class="nf-section-title mb-3">Cancelar turno</h1>
                    <p class="text-muted">
                        ¿Seguro que querés cancelar este turno?
                    </p>

                    <dl class="row">
                        <dt class="col-sm-4">Fecha y hora</dt>
                        <dd class="col-sm-8">@Model.Start.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-4">Servicio</dt>
                        <dd class="col-sm-8">@Model.Service.Name</dd>

                        <dt class="col-sm-4">Estilista</dt>
                        <dd class="col-sm-8">@Model.Stylist.Name</dd>
                    </dl>

                    <form asp-action="Cancel" method="post">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn nf-btn-danger me-2">Sí, cancelar</button>
                        <a asp-action="My" class="btn nf-btn-secondary">Volver</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
